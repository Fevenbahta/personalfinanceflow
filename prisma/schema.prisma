// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  username       String
  email          String   @unique
  monthlyIncome  Float    @default(0)
  createdAt      DateTime @default(now())

  accounts        Account[]
  transactions    Transaction[]
  budgets         BudgetAllocation[]
  goals           Goal[]
  notifications   Notification[]
  aiInsights      AIInsight[]
  monthlyBudgets  MonthlyBudget[]    // Added this relation
  monthlyInsights MonthlyInsight[]    // Added this relation
  spendingPatterns SpendingPattern[]  // Added this relation
}

model Account {
  id        String   @id @default(uuid())
  userId    String
  name      String
  type      String
  balance   Float    @default(0)
  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  accountId       String
  amount          Float
  type            String
  category        String?
  description     String?
  transactionDate DateTime @default(now())
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model BudgetAllocation {
  id                    String   @id @default(uuid())
  userId                String
  month                 DateTime?  @map("month") // Make it optional with ?
  category              String
  percentage            Float
  recommendedPercentage Float?
  aiAdjusted            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyBudget  MonthlyBudget? @relation(fields: [userId, month], references: [userId, month])

  @@unique([userId, category, month])
  @@map("budget_allocations")
}

model Goal {
  id            String   @id @default(uuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  targetDate    DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AIInsight {
  id          String   @id @default(uuid())
  userId      String
  insightText String
  type        String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

model MonthlyBudget {
  id            String   @id @default(uuid())
  userId        String
  month         DateTime @map("month") // First day of the month
  totalIncome   Float    @default(0)
  totalExpenses Float    @default(0)
  netSavings    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations BudgetAllocation[] @relation // This connects to BudgetAllocation via userId+month
  insights    MonthlyInsight[]

  @@unique([userId, month])
  @@map("monthly_budgets")
}

model MonthlyInsight {
  id              String   @id @default(uuid())
  userId          String
  monthlyBudgetId String
  type            String   // "PREDICTION", "SUGGESTION", "ALERT", "ACHIEVEMENT"
  title           String
  description     String
  impact          Float?   // Monetary impact if applicable
  category        String?  // Related category
  isActionable    Boolean  @default(false)
  actionType      String?  // "SAVE", "INVEST", "CUT_EXPENSE", "TREAT_YOURSELF"
  actionData      Json?    // Additional action data
  createdAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyBudget MonthlyBudget @relation(fields: [monthlyBudgetId], references: [id], onDelete: Cascade)

  @@map("monthly_insights")
}

model SpendingPattern {
  id          String   @id @default(uuid())
  userId      String
  category    String
  avgAmount   Float    // Average monthly spending
  trend       Float    // Percentage change over last 3 months
  volatility  Float    // Spending variability
  seasonality String? // Seasonal pattern if any
  insights    Json?    // AI-generated insights
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("spending_patterns")
}